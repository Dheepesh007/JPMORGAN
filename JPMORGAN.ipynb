      "source": [
        "# Optimization using derivative\n",
        "\n",
        "import sympy as sp\n",
        "\n",
        "# define variable\n",
        "x = sp.symbols('x')\n",
        "\n",
        "# define function\n",
        "E = x**2 - 6*x + 10\n",
        "\n",
        "# derivative\n",
        "dE_dx = sp.diff(E, x)\n",
        "\n",
        "# solve derivative = 0\n",
        "solution = sp.solve(dE_dx, x)\n",
        "\n",
        "print(\"Minimum Energy at x =\", solution[0])"
      ]
    }
  ]
}